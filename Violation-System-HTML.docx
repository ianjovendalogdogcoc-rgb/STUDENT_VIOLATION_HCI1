                <th>No.</th>
                <th>Name</th>
                <th>ID</th>
                <th>Dept</th>
                <th>Section</th>
                <th>Year</th>
                <th>Violation</th>
                <th>Description</th>
                <th>Date</th>
                <th>Location</th>
                <th>Reported By</th>
                <th>Action</th>
                <th>Status</th>
            </tr>

