<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>PHINMA COC Student Violation Monitoring</title>
<link rel="stylesheet " href="style.css">

</head>

<body>

<!-- NAVBAR -->
<nav>
    <h2>PHINMA COC</h2>
    <div>
        <a href="#home" class="active">Home</a>
        <a href="#add" class="active">Add</a>
        <a href="#records" class="active">Record</a>
        <a href="#about" class="active">About</a>
        <a href="#contact" class="active">Contact</a>
</nav>

<!-- HOME -->
<section id="home">
   
        <div class="logo"></div>
       
        <div class="home-text">
            <h2>Student Violation Monitoring System</h2>
            <p>Welcome! This system helps monitor and record student violations in PHINMA COC.</p>
        </div>
   
</section>

<!-- RECORDS -->
<section id="add">
    <div class="card">
        <h2>Add Violation Record</h2>

        <input type="text" placeholder="Student Name">
        <input type="text" placeholder="Student ID">
        <input type="text" placeholder="Department">
        <input type="text" placeholder="Section">
        <input type="text" placeholder="Year">

        <input type="text" placeholder="Violation">
        <input type="text" placeholder="Description">
        <input type="date">
        <input type="text" placeholder="Location">
        <input type="text" placeholder="Reported By">


        <input type="text" placeholder="Action">

        <!-- STATUS INPUT -->
        <select>
            <option disabled selected>Status</option>
            <option>Pending</option>
            <option>Solved</option>
            <option>Archived</option>
        </select>

        <button>Add Record</button>
        <p style="color: gray; font-size: 12px;">(Static only – no functionality yet)</p>
    </div>
</section>
<section id="records">   <!-- RECORD TABLE -->
    <div class="card">
        <h2>Violation Records</h2>
        <div class="table-container">
        <table>
