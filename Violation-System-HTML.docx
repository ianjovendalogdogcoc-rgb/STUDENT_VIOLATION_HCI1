</section>

<!-- ABOUT -->
<section id="about">
    <div class="card">
        <h2>About Us</h2>
        <p>The PHINMA COC Student Violation Monitoring System <br> is a program designed to help authorized users efficiently<br> manage student violation records. It allows users to view,<br> add, edit, and  archive violations. With this system, authorized<br> staff or guidance personnel can reduce errors, maintain accurate<br> information, and keep the student violation records<br> organized and easily accessible.</p>
    </div>
</section>

<!-- CONTACT -->
<section id="contact">
    <div class="card">
        <h2>Contact Us</h2>

        <input type="text" placeholder="Full Name">
        <input type="email" placeholder="Email">
        <textarea rows="5" placeholder="Your Message"></textarea>

        <button>Send Message</button>
        <p style="color: gray; font-size: 12px;">(Demo only – not functional)</p>
    </div>
</section>

</body>
</html>
